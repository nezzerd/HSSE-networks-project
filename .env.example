# Скопируйте этот файл в .env и заполните значения:  cp .env.example .env

# Домен для HTTPS. Для локального теста оставьте localhost.
# Для боевого сервера укажите свой домен (Caddy сам получит сертификат Let's Encrypt).
DOMAIN=localhost

# Параметры базы данных PostgreSQL
DB_NAME=searchengine
DB_USER=searchengine
# ОБЯЗАТЕЛЬНО задайте надёжный пароль — без него compose не запустится.
DB_PASSWORD=change_me_to_a_strong_password
